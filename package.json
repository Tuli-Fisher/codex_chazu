{
  "name": "chazu-2-codex",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm -w apps/web run dev",
    "dev:api": "npm -w apps/api run dev",
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "build:web": "npm -w apps/web run build",
    "build:web:vercel": "npm -w apps/web run build:vercel",
    "build": "npm run --workspaces build",
    "preview": "npm -w apps/web run preview",
    "typecheck": "npm run --workspaces typecheck",
    "lint": "npm -w apps/web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
